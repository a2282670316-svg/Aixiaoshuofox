{
  "name": "novel-forge",
  "version": "0.7.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "install:ci": "npm ci",
    "dev": "vite",
    "build": "node scripts/build-verified.mjs",
    "start": "vinext start",
    "test": "npm run build && node --test tests/rendered-html.test.mjs && tsx --test tests/auto-novel.test.ts",
    "validate:artifact": "node scripts/validate-artifact.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate",
    "background:worker": "node --env-file-if-exists=.env.local scripts/background-worker.mjs",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run analyze && npm test",
    "security:audit": "npm audit --omit=dev --registry=https://registry.npmjs.org",
    "analyze:unused": "knip --no-progress",
    "analyze:duplicates": "jscpd app lib db worker --min-lines 8 --min-tokens 60 --threshold 2 --reporters console",
    "analyze": "npm run analyze:unused && npm run analyze:duplicates"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "openai": "^6.46.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.44.0",
    "@cloudflare/workers-types": "5.20260711.1",
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "22.19.19",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitejs/plugin-rsc": "0.5.27",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "jscpd": "5.0.12",
    "knip": "6.26.0",
    "react-server-dom-webpack": "19.2.7",
    "tailwindcss": "4.3.2",
    "tsx": "^4.23.0",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.4",
    "wrangler": "4.110.0"
  },
  "type": "module",
  "displayName": "万象小说工坊",
  "overrides": {
    "ws": "8.21.0",
    "postcss": "8.5.16"
  }
}
