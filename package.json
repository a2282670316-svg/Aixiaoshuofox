{
  "name": "novel-forge",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "install:ci": "npm ci",
    "dev": "vite",
    "build": "node scripts/build-verified.mjs",
    "start": "vinext start",
    "test": "npm run build && node --test tests/rendered-html.test.mjs && tsx --test tests/auto-novel.test.ts",
    "validate:artifact": "node scripts/validate-artifact.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate",
    "background:worker": "node --env-file-if-exists=.env.local scripts/background-worker.mjs"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.6",
    "openai": "^6.46.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "^4.23.0",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module",
  "displayName": "万象小说工坊"
}
